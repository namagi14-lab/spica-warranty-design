<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- HostPCProgram（C0L-0160）のベースURL。MiniPC はここに対して API を叩く -->
    <add key="HostPcBaseUrl" value="http://192.168.1.1/" />

    <!--
      MiniPC 上で立てるコールバック受信サーバーの待ち受けURL。
      localhost は開発用。LAN 内の他ホスト（HostPC）から受けるには
      "http://+:8080/" などにし、管理者権限で netsh の urlacl 登録が必要:
        netsh http add urlacl url=http://+:8080/ user=Everyone
    -->
    <add key="ListenUrl" value="http://localhost:8080/" />

    <!-- 工程を1回流すデモ用シリアル番号。空の場合はサーバー待ち受けのみ行う -->
    <add key="SerialNo" value="" />

    <!-- 工程JSONファイルのローカル保存先ディレクトリ -->
    <add key="LocalFileDir" value="process_files" />
  </appSettings>
</configuration>
