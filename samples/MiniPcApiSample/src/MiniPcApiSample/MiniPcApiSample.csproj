<Project Sdk="Microsoft.NET.Sdk">

  <!--
    MiniPC（C0L-0161 保証工程制御Program）の API サンプル。
    Windows 前提・.NET Framework 4.8 をターゲットにしています。
    HTTP サーバー（OWIN セルフホスト Web API）と HostPC API クライアントを含みます。
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <RootNamespace>MiniPcApiSample</RootNamespace>
    <AssemblyName>MiniPcApiSample</AssemblyName>
    <Nullable>disable</Nullable>
    <AppConfig>App.config</AppConfig>
  </PropertyGroup>

  <ItemGroup>
    <!-- OWIN セルフホスト + Web API（IIS なしで HTTP エンドポイントを立てる） -->
    <PackageReference Include="Microsoft.AspNet.WebApi.OwinSelfHost" Version="5.2.9" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <!-- .NET Framework の標準アセンブリ参照 -->
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Configuration" />
  </ItemGroup>

</Project>
